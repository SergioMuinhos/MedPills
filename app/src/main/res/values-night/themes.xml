<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MedPills" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">#F8FAFC</item>

        <!-- Dark theme specific overrides -->
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/app_background</item>

        <!-- Typography scales -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.MedPills.Headline1</item>
        <item name="textAppearanceBody1">@style/TextAppearance.MedPills.Body1</item>
    </style>
</resources>
